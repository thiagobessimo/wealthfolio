# Wealthfolio Web Mode Environment Configuration
# Copy this file to .env.web and customize for your local development setup
# All variables are optional and will use defaults if not set

# =============================================================================
# SERVER CONFIGURATION (Axum Backend)
# =============================================================================

# Server bind address (default: 0.0.0.0:8088)
# For local development, use 127.0.0.1 to bind only to localhost
# For Docker or network access, use 0.0.0.0
WF_LISTEN_ADDR=127.0.0.1:8088

# SQLite database path (default: ./db/app.db)
# Can be a file path or directory (if directory, app.db will be created inside)
# Examples:
#   - ./db/web-dev.db (file path)
#   - ./db (directory, will use ./db/app.db)
WF_DB_PATH=./db/web-dev.db

# CORS allowed origins (default: *)
# Comma-separated list of origins that can access the API
# Set this to restrict cross-origin requests for security
# Examples:
#   - http://localhost:1420 (Vite dev server only)
#   - http://localhost:1420,http://localhost:3000 (multiple origins)
#   - * (allow all origins - not recommended for production)
WF_CORS_ALLOW_ORIGINS=http://localhost:1420

# Request timeout in milliseconds (default: 30000)
# Maximum time to wait for a request to complete
WF_REQUEST_TIMEOUT_MS=30000

# Static files directory (default: dist)
# Directory containing the built frontend assets
# Only relevant when running the server in production mode
WF_STATIC_DIR=dist

# =============================================================================
# SECRETS & SECURITY
# =============================================================================

# Encryption key used for both secrets at rest and JWT signing (required)
# Must be a 32-byte key, either:
#   - Base64-encoded string (recommended): Generate with 'openssl rand -base64 32'
#   - 32-character ASCII string
# SECURITY: Keep this key secure and never commit it to version control
WF_SECRET_KEY=

# Example generation commands:
# macOS/Linux:  export WF_SECRET_KEY=$(openssl rand -base64 32)
# Windows PS:   $env:WF_SECRET_KEY=$(openssl rand -base64 32)

# Authentication for web mode (required to enable login)
# Provide an Argon2id PHC string. Generate with argon2.online or:
#   printf 'your-password' | argon2 yoursalt16chars! -id -e
# If reusing this value with Docker Compose .env/--env-file, single-quote it
# or double every $ in the hash ($$argon2id$$...)
WF_AUTH_PASSWORD_HASH=

# Optional JWT access token lifetime in minutes (default: 60)
# WF_AUTH_TOKEN_TTL_MINUTES=60

# =============================================================================
# OIDC / SSO (optional)
# =============================================================================
#
# Enable Single Sign-On via any OpenID Connect provider (Authentik, PocketID,
# Authelia, Keycloak, etc.). OIDC is an alternative to the password above:
#   - Set WF_OIDC_* only          -> login page shows just "Sign in with SSO"
#   - Set WF_AUTH_PASSWORD_HASH    -> login page shows just the password field
#   - Set both                     -> login page shows password AND SSO
# Successful SSO mints the same session cookie as password login.
#
# OIDC is enabled when BOTH issuer URL and client id are set.

# Issuer URL (the base URL; discovery hits <issuer>/.well-known/openid-configuration)
# WF_OIDC_ISSUER_URL=https://auth.example.com/application/o/wealthfolio/

# Client credentials registered with your IdP.
# WF_OIDC_CLIENT_ID=
# Client secret is optional (PKCE is always used); set it for confidential clients.
# WF_OIDC_CLIENT_SECRET=

# Redirect URL — must be registered in the IdP and reachable by the browser.
# WF_OIDC_REDIRECT_URL=https://your.host/api/v1/auth/oidc/callback

# Space-separated scopes (default: "openid email profile")
# WF_OIDC_SCOPES=openid email profile

# Optional allowlist. With NEITHER set, ANY user your IdP authenticates is granted
# access (fine for single-user IdPs; risky on a shared corporate IdP).
# Comma-separated, matched against the ID token's email / sub claims.
# NOTE: an email is only honored when the IdP marks it email_verified=true.
# WF_OIDC_ALLOWED_SUBS is the stronger control (the sub is stable and IdP-scoped)
# and is recommended on shared / multi-tenant IdPs.
# WF_OIDC_ALLOWED_EMAILS=you@example.com
# WF_OIDC_ALLOWED_SUBS=

# Logout: when the IdP advertises an end_session_endpoint, sign-out also performs
# RP-Initiated Logout (ends the IdP session), else it's local-only. Auto-detected.
# Set this to land back on the app after IdP logout — it MUST be registered in the
# IdP (e.g. Keycloak "Valid post logout redirect URIs"). If unset, the IdP shows
# its own logged-out page.
# WF_OIDC_POST_LOGOUT_REDIRECT_URL=https://your.host/
# Force local-only logout even if the IdP supports RP-initiated logout.
# WF_OIDC_RP_LOGOUT=false

# Secrets storage file path (optional)
# Location where encrypted secrets are stored (default: <data-root>/secrets.json)
# The data root is derived from the database path
# WF_SECRET_FILE=

# =============================================================================
# ADDONS CONFIGURATION
# =============================================================================

# Addons directory path (optional)
# Location where addons are installed and loaded from
# If not set, defaults to <data-root>/addons (derived from database path)
# WF_ADDONS_DIR=

# =============================================================================
# VITE DEVELOPMENT SERVER CONFIGURATION
# =============================================================================

# Backend API URL for Vite proxy (default: http://127.0.0.1:8088)
# This tells Vite where to proxy API requests during development
# Should match WF_LISTEN_ADDR above
VITE_API_TARGET=http://127.0.0.1:8088

# =============================================================================
# USAGE NOTES
# =============================================================================
#
# 1. Development Mode:
#    - Run 'pnpm run dev:web' to start both Vite and the Axum server
#    - Access the app at http://localhost:1420 (Vite dev server)
#    - API requests are proxied to the backend at WF_LISTEN_ADDR
#
# 2. Production Mode (Docker):
#    - Build: docker build -t wealthfolio-web .
#    - Run: docker run -e WF_LISTEN_ADDR=0.0.0.0:8088 -p 8088:8088 wealthfolio-web
#    - Access at http://localhost:8088 (serves both frontend and API)
#
# 3. Security Best Practices:
#    - Always set WF_SECRET_KEY in production
#    - Restrict WF_CORS_ALLOW_ORIGINS to known origins
#    - Use HTTPS in production (consider reverse proxy like nginx/Caddy)
#    - Keep this file (.env.web) out of version control
#    - Never commit WF_SECRET_KEY to git
#
# 4. Database Path Recommendations:
#    - Development: Use ./db/web-dev.db to separate from desktop app data
#    - Production: Use absolute paths or Docker volumes for persistence
#    - Backup regularly, especially before updates
#
# =============================================================================
